// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum USER_ROLE {
  SUPER
  ADMIN
  USER
}

model Product {
  id          String  @id @default(uuid())
  code        String  @unique
  name        String
  description String?
  quantity    Int
  price       Int
  image       String?
}

model User {
  id           String   @id @default(uuid())
  firstName    String
  lastName     String
  email        String
  password     String
  username     String @unique()
  active       Boolean 
  role USER_ROLE @default(USER)
  createdAt    DateTime
  profileImage String?
}
